RewriteEngine On

# 1. Solo redireccionar la raíz vacía al punto de entrada
RewriteRule ^$ /TuCooperativa/client/dist/ [R,L,QSA]

# 2. Redireccionar cualquier otra ruta que NO sea api, bot, client o driver_sim
RewriteCond %{REQUEST_URI} !^/TuCooperativa/(api|bot|client|driver_sim|docs) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Redireccionar dinámicamente al dashboard sin anidar carpetas (Evita el loop dist/dist)
RewriteRule ^(.*)$ /TuCooperativa/client/dist/ [R,L,QSA]

# 3. Anti-Cache for Modern UI (v17.1-Stable)
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</FilesMatch>
